{ // inspiration from: https://github.com/topics/waybar
  "layer": "top",
  "position": "top",

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["privacy", "tray", "custom/systemd-failed", "temperature", "cpu", "memory", "disk", "pulseaudio", "network", "battery"],

  "clock": {
    "format": "{:%a %d %b  %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "custom/systemd-failed": {
    "exec": "~/.config/waybar/scripts/failed-units.sh",
    "interval": 180,
    "format": "systemd failed units: {}"
  },

  "pulseaudio": {
    "format": "Vol {volume}%",
    "scroll-step": 5
  },

  "network": {
    "interval": 3,
    "format-ethernet": "󰈀  LAN",
    "format-wifi": "  {essid}",
    "format-disconnected": "󰤮",
    "tooltip-format-ethernet": "Ethernet: {ifname}\nIP: {ipaddr}\nDown: {bandwidthDownBits} Up: {bandwidthUpBits}"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰂄 {capacity}%",
    "format-alt": "{icon} {time}",
    "format-full": "󱈑 {capacity}%",
    "format-icons": ["󱊡", "󱊢", "󱊣"]
  },

  "temperature": {
    //"thermal-zone": 1, // less accurate
    "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input", // most acc key but value might be diff for you.
    "critical-threshold": 80,
    "format-critical": "{temperatureC}°C ⚠️",
    "format": "{temperatureC}°C"
  },

  "cpu": {
    "format": "CPU {usage}% ({load})",
    "interval": 1
  },

  "memory": {
    "format": "{used:0.1f}G/{total:0.1f}G  [{swapUsed}/{swapTotal}]"
  },

  "disk": {
    "interval": 60,
    "format": "Disk {percentage_used}%",
    "path": "/"
  },

  "privacy": {
    "icon-spacing": 4,
    "icon-size": 18,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 20
      },
      {
        "type": "audio-out",
        "tooltip": true,
        "tooltip-icon-size": 20
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 20
      }
    ]
  }
}
